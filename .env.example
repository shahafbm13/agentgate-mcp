# Database (use 127.0.0.1 on Windows to avoid IPv6 localhost issues)
DATABASE_URL=postgresql://agentgate:agentgate@127.0.0.1:5432/agentgate

# MCP Server
PORT=3000
TRANSPORT=http
MCP_RESOURCE_URI=http://localhost:3000/mcp
BASE_URL=http://localhost:3000

# JWT validation (resource server)
JWT_ISSUER=http://localhost:9000
JWT_AUDIENCE=http://localhost:3000/mcp
JWKS_URI=http://localhost:9000/.well-known/jwks.json
AUTH_SERVER_URL=http://localhost:9000

# stdio mode token (Cursor local dev)
AGENTGATE_ACCESS_TOKEN=

# Notification API
NOTIFICATION_API_URL=http://localhost:9001
NOTIFICATION_API_KEY=dev-notification-key

# Logging
LOG_LEVEL=info
